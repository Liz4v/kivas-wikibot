# Copy to .env and fill in. Never commit .env.
DEFAULT_LANG=pt

# These wikis have no Special:BotPasswords (pre-MW-1.27 or disabled),
# so the bot uses legacy login.
PT_BOT_USERNAME=
PT_BOT_PASSWORD=
EN_BOT_USERNAME=
EN_BOT_PASSWORD=

# Cloudflare workaround, spoof user agent and cf_clearance cookie
USER_AGENT_SPOOF=
CF_CLEARANCE=
CF_CLEARANCE_EXPIRES=
